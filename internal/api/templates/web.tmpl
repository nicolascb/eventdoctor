{{ define "web" }}
<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <title>EventDoctor - Catálogo de Eventos</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <style>
        body {
            font-family: system-ui, Arial, sans-serif;
            margin: 0;
            background: #121417;
            color: #e3e6eb;
        }

        header {
            background: #1e2530;
            padding: 16px 32px;
            box-shadow: 0 2px 4px rgba(0, 0, 0, .4);
        }

        h1 {
            margin: 0;
            font-size: 20px;
        }

        main {
            padding: 24px 32px;
            display: grid;
            grid-template-columns: 1fr 350px;
            gap: 24px;
        }

        .content {
            min-width: 0;
        }

        .sidebar {
            background: #1b222c;
            border-radius: 8px;
            padding: 20px;
            border: 1px solid #253041;
            max-height: calc(100vh - 150px);
            overflow-y: auto;
            position: sticky;
            top: 100px;
        }

        .sidebar h3 {
            margin: 0 0 16px;
            font-size: 14px;
            text-transform: uppercase;
            color: #94a2b3;
            letter-spacing: 0.5px;
        }

        .sidebar-empty {
            color: #94a2b3;
            text-align: center;
            padding: 40px 0;
            font-size: 13px;
        }

        .detail-section {
            margin-bottom: 20px;
            padding-bottom: 20px;
            border-bottom: 1px solid #253041;
        }

        .detail-section:last-child {
            border-bottom: none;
            margin-bottom: 0;
            padding-bottom: 0;
        }

        .detail-label {
            font-size: 11px;
            color: #94a2b3;
            text-transform: uppercase;
            margin-bottom: 6px;
            font-weight: 600;
            letter-spacing: 0.5px;
        }

        .detail-value {
            font-size: 13px;
            color: #e3e6eb;
            word-break: break-word;
        }

        .detail-value code {
            background: #253041;
            padding: 2px 4px;
            border-radius: 4px;
            font-size: 12px;
        }

        .headers-list {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .header-item {
            background: #253041;
            padding: 8px;
            border-radius: 4px;
            font-size: 12px;
        }

        .header-name {
            color: #87d79a;
            font-weight: 600;
        }

        .header-description {
            color: #94a2b3;
            font-size: 11px;
            margin-top: 2px;
        }

        section.topic {
            margin-bottom: 48px;
        }

        .topic-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 8px;
            cursor: pointer;
            padding: 8px;
            border-radius: 6px;
            transition: background 0.2s;
            user-select: none;
        }

        .topic-header:hover {
            background: #1b232d;
        }

        .topic-header h2 {
            margin: 0;
            font-size: 18px;
        }

        .badge {
            background: #2d3b4d;
            padding: 2px 8px;
            border-radius: 12px;
            font-size: 12px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 12px;
            font-size: 14px;
            cursor: pointer;
        }

        th,
        td {
            padding: 8px 10px;
            text-align: left;
            vertical-align: top;
        }

        th {
            background: #253041;
            position: sticky;
            top: 0;
        }

        tbody tr {
            transition: background 0.15s;
        }

        tbody tr:nth-child(even) {
            background: #1b222c;
        }

        tbody tr:nth-child(odd) {
            background: #171d26;
        }

        tbody tr:hover {
            background: #253041;
        }

        code {
            background: #253041;
            padding: 2px 4px;
            border-radius: 4px;
            font-size: 12px;
        }

        .deprecated {
            text-decoration: line-through;
            opacity: .6;
        }

        .footer {
            margin-top: 64px;
            font-size: 12px;
            color: #8a949f;
            text-align: center;
            padding: 24px 0;
            grid-column: 1 / -1;
        }

        a {
            color: #5fb0ff;
            text-decoration: none;
        }

        a:hover {
            text-decoration: underline;
        }

        .tag-deprecated {
            background: #5b2731;
            color: #ff9aa9;
        }

        .tag-owner {
            background: #254d2d;
            color: #87d79a;
        }

        small {
            color: #94a2b3;
        }

        ul.inline {
            list-style: none;
            margin: 0;
            padding: 0;
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
        }

        ul.inline li {
            background: #253041;
            padding: 2px 6px;
            border-radius: 6px;
        }

        .search-box {
            margin: 0 0 24px 0;
            grid-column: 1 / -1;
        }

        .search-box input {
            width: 100%;
            padding: 10px 14px;
            border: 1px solid #2e3a49;
            border-radius: 8px;
            background: #1b232d;
            color: #e3e6eb;
        }

        .hidden {
            display: none;
        }

        @media (max-width: 1200px) {
            main {
                grid-template-columns: 1fr;
            }

            .sidebar {
                position: relative;
                top: auto;
                max-height: none;
            }
        }

        @media (max-width: 900px) {

            table,
            thead,
            tbody,
            th,
            td,
            tr {
                display: block;
            }

            thead {
                display: none;
            }

            tbody tr {
                margin-bottom: 16px;
                border: 1px solid #253041;
                border-radius: 8px;
                overflow: hidden;
            }

            td {
                padding: 6px 10px;
            }

            td::before {
                font-weight: 600;
                display: block;
                margin-bottom: 2px;
                color: #94a2b3;
            }

            td[data-label]::before {
                content: attr(data-label);
            }
        }
    </style>
</head>

<body>
    <header>
        <h1>EventDoctor - Catálogo de Eventos</h1>
    </header>
    <main>
        <div class="content">
            <div class="search-box">
                <input type="text" id="search" placeholder="Filtrar por evento, tópico, produtor ou consumidor...">
            </div>
            {{ if not .Topics }}
            <p>Nenhum tópico cadastrado.</p>
            {{ end }}
            {{ range .Topics }}
            <section class="topic" data-topic="{{ .Name }}" data-owner="{{ .Owner }}">
                <div class="topic-header" onclick="handleTopicClick('{{ .Name }}')">
                    <h2>{{ .Name }}</h2>
                    <span class="badge tag-owner">owner: {{ .Owner }}</span>
                    <small>{{ len .Events }} eventos</small>
                </div>
                <table>
                    <thead>
                        <tr>
                            <th style="width:20%">Evento</th>
                            <th style="width:10%">Versão</th>
                            <th style="width:30%">Schema</th>
                            <th style="width:20%">Produtores</th>
                            <th style="width:20%">Consumidores</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{ range .Events }}
                        <tr class="row-event" data-event="{{ .Type }}" data-version="{{ .Version }}"
                            data-schema="{{ .SchemaURL }}" data-deprecated="{{ .Deprecated }}"
                            data-headers="{{ range .Headers }}{{ .Name }}|{{ .Description }}~ {{ end }}"
                            data-producers="{{ range .Producers }}{{ .Name }}:{{ .Writes }}|{{ .Repository }}~ {{ end }}"
                            data-consumers="{{ range .Consumers }}{{ .Name }}|{{ .EventVersion }}|{{ .Repository }}~ {{ end }}"
                            onclick="handleEventClick(event, this)">
                            <td data-label="Evento">
                                <code class="{{ if .Deprecated }}deprecated{{ end }}">{{ .Type }}</code>
                            </td>
                            <td data-label="Versão">
                                {{ if .Version }}<code>{{ .Version }}</code>{{ else }}<small>-</small>{{ end }}
                            </td>
                            <td data-label="Schema">
                                <a href="{{ .SchemaURL }}" target="_blank" rel="noopener"
                                    onclick="event.stopPropagation()">{{ .SchemaURL }}</a>
                            </td>
                            <td data-label="Produtores">
                                {{ if .Producers }}
                                {{ $first := index .Producers 0 }}
                                <ul class="inline">
                                    <li title="{{ if $first.Repository }}{{ $first.Repository }}{{ end }}">
                                        {{ $first.Name }}{{ if not $first.Writes }}<span class="badge"
                                            style="background: #4d3b2d; color: #ffb987; font-size: 10px; margin-left: 4px;">read-only</span>{{
                                        end }}
                                    </li>
                                    {{ if gt (len .Producers) 1 }}
                                    <li style="background: #254d2d; color: #87d79a;">(+{{ subtract (len .Producers) 1
                                        }})</li>
                                    {{ end }}
                                </ul>
                                {{ else }}<small>-</small>{{ end }}
                            </td>
                            <td data-label="Consumidores">
                                {{ if .Consumers }}
                                {{ $first := index .Consumers 0 }}
                                <ul class="inline">
                                    <li title="{{ if $first.Repository }}{{ $first.Repository }}{{ end }}">
                                        {{ $first.Name }}{{ if $first.EventVersion }}<span class="badge"
                                            style="background: #2d3b4d; color: #94a2b3; font-size: 10px; margin-left: 4px;">{{
                                            $first.EventVersion }}</span>{{ end }}
                                    </li>
                                    {{ if gt (len .Consumers) 1 }}
                                    <li style="background: #2d3b4d; color: #94a2b3;">(+{{ subtract (len .Consumers) 1
                                        }})</li>
                                    {{ end }}
                                </ul>
                                {{ else }}<small>-</small>{{ end }}
                            </td>
                        </tr>
                        {{ end }}
                    </tbody>
                </table>
            </section>
            {{ end }}
            <div class="footer">
                Gerado pelo EventDoctor • Página estática
            </div>
        </div>

        <div class="sidebar">
            <div id="sidebar-content">
                <div class="sidebar-empty">
                    Clique em um tópico ou evento para ver detalhes
                </div>
            </div>
        </div>
    </main>

    <script>
        // Utilitários
        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        function updateSidebar(html) {
            document.getElementById('sidebar-content').innerHTML = html;
        }

        function parseDelimitedData(data, parser) {
            if (!data) return [];
            return data.split('~ ').filter(Boolean).map(parser);
        }

        // Handlers de clique
        function handleTopicClick(topicName) {
            const topic = document.querySelector(`[data-topic="${topicName}"]`);
            if (!topic) return;

            const owner = topic.dataset.owner;

            // Coletar todos os consumidores únicos do tópico
            const consumersMap = new Map();
            topic.querySelectorAll('.row-event').forEach(row => {
                const consumers = parseDelimitedData(row.dataset.consumers, c => {
                    const [name, version, repo] = c.split('|');
                    return { name, version, repo };
                });
                consumers.forEach(c => {
                    if (!consumersMap.has(c.name)) {
                        consumersMap.set(c.name, c);
                    }
                });
            });

            const uniqueConsumers = Array.from(consumersMap.values());

            let html = `
                <div class="detail-section">
                    <div class="detail-label">Tópico</div>
                    <div class="detail-value"><code>${escapeHtml(topicName)}</code></div>
                </div>
                <div class="detail-section">
                    <div class="detail-label">Owner</div>
                    <div class="detail-value">${escapeHtml(owner)}</div>
                </div>
            `;

            if (uniqueConsumers.length > 0) {
                html += `
                    <div class="detail-section">
                        <div class="detail-label">Consumidores (${uniqueConsumers.length})</div>
                        <div class="headers-list">
                            ${uniqueConsumers.map(c => `
                                <div class="header-item">
                                    <div class="header-name">${escapeHtml(c.name)}</div>
                                    ${c.repo && c.repo !== 'null' ? `<div class="header-description">${escapeHtml(c.repo)}</div>` : ''}
                                </div>
                            `).join('')}
                        </div>
                    </div>
                `;
            } else {
                html += `
                    <div class="detail-section">
                        <div class="detail-label">Consumidores</div>
                        <div class="detail-value"><small>Nenhum consumidor registrado</small></div>
                    </div>
                `;
            }

            updateSidebar(html);
        }

        function handleEventClick(event, row) {
            event.stopPropagation();

            const topic = row.closest('.topic').dataset.topic;
            const eventType = row.dataset.event;
            const version = row.dataset.version || '-';
            const deprecated = row.dataset.deprecated === 'true';

            const headers = parseDelimitedData(row.dataset.headers, h => {
                const [name, desc] = h.split('|');
                return { name, desc };
            });

            const producers = parseDelimitedData(row.dataset.producers, p => {
                const [serviceInfo, repo] = p.split('|');
                const [name, writes] = serviceInfo.split(':');
                return { name, writes: writes === 'true', repo };
            });

            const consumers = parseDelimitedData(row.dataset.consumers, c => {
                const [name, version, repo] = c.split('|');
                return { name, version, repo };
            });

            let html = `
                <div class="detail-section">
                    <div class="detail-label">Tópico</div>
                    <div class="detail-value"><code>${escapeHtml(topic)}</code></div>
                </div>
                <div class="detail-section">
                    <div class="detail-label">Evento</div>
                    <div class="detail-value"><code>${escapeHtml(eventType)}</code></div>
                </div>
                <div class="detail-section">
                    <div class="detail-label">Versão</div>
                    <div class="detail-value">${version !== '-' ? `<code>${escapeHtml(version)}</code>` : '-'}</div>
                </div>
            `;

            if (deprecated) {
                html += `
                    <div class="detail-section">
                        <div class="detail-label">Status</div>
                        <div class="detail-value"><span class="badge tag-deprecated">deprecated</span></div>
                    </div>
                `;
            }

            if (headers.length > 0) {
                html += `
                    <div class="detail-section">
                        <div class="detail-label">Headers HTTP</div>
                        <div class="headers-list">
                            ${headers.map(h => `
                                <div class="header-item">
                                    <div class="header-name">${escapeHtml(h.name)}</div>
                                    ${h.desc ? `<div class="header-description">${escapeHtml(h.desc)}</div>` : ''}
                                </div>
                            `).join('')}
                        </div>
                    </div>
                `;
            }

            if (producers.length > 0) {
                html += `
                    <div class="detail-section">
                        <div class="detail-label">Produtores</div>
                        <div class="headers-list">
                            ${producers.map(p => `
                                <div class="header-item">
                                    <div class="header-name">${escapeHtml(p.name)}</div>
                                    ${p.repo && p.repo !== 'null' ? `<div class="header-description">${escapeHtml(p.repo)}</div>` : ''}
                                </div>
                            `).join('')}
                        </div>
                    </div>
                `;
            }

            if (consumers.length > 0) {
                html += `
                    <div class="detail-section">
                        <div class="detail-label">Consumidores</div>
                        <div class="headers-list">
                            ${consumers.map(c => `
                                <div class="header-item">
                                    <div class="header-name">${escapeHtml(c.name)}</div>
                                    ${c.repo && c.repo !== 'null' ? `<div class="header-description">${escapeHtml(c.repo)}</div>` : ''}
                                </div>
                            `).join('')}
                        </div>
                    </div>
                `;
            }

            updateSidebar(html);
        }

        // Filtro de busca
        document.getElementById('search').addEventListener('input', function () {
            const term = this.value.toLowerCase().trim();

            document.querySelectorAll('.topic').forEach(topic => {
                let anyVisible = false;

                topic.querySelectorAll('.row-event').forEach(row => {
                    const searchText = [
                        topic.dataset.topic,
                        row.dataset.event,
                        row.dataset.producers,
                        row.dataset.consumers
                    ].join(' ').toLowerCase();

                    const isVisible = !term || searchText.includes(term);
                    row.style.display = isVisible ? '' : 'none';
                    if (isVisible) anyVisible = true;
                });

                topic.style.display = anyVisible ? '' : 'none';
            });
        });
    </script>
</body>

</html>
{{ end }}