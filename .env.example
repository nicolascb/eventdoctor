# Configuração da API EventDoctor

# Porta do servidor HTTP
PORT=:8087

# Driver do banco de dados: sqlite3 (padrão), postgres ou mysql
DB_DRIVER=sqlite3

# Connection string - varia conforme o driver:
# SQLite: ./data.db ou file:./data.db
# PostgreSQL: postgres://user:password@localhost:5432/dbname?sslmode=disable
# MySQL: user:password@tcp(localhost:3306)/dbname

DB_CONNECTION=./data.db

# Deprecated - usar DB_CONNECTION ao invés disso
# SQLITE_PATH=./data.db
